generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  password     String
  name         String
  avatarUrl    String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  householdMembers HouseholdMember[]
  bills            Bill[]
  payments         Payment[]
  aiInsights       AIInsight[]
  chatMessages     ChatMessage[]
}

model Household {
  id          String   @id @default(cuid())
  name        String
  inviteCode  String   @unique @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members  HouseholdMember[]
  bills    Bill[]
}

model HouseholdMember {
  id          String    @id @default(cuid())
  userId      String
  householdId String
  role        Role      @default(MEMBER)
  joinedAt    DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@unique([userId, householdId])
  @@index([userId])
  @@index([householdId])
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

model Category {
  id          String   @id @default(cuid())
  name        String
  icon        String?
  color       String?
  isDefault   Boolean  @default(false)
  householdId String?
  createdAt   DateTime @default(now())

  bills Bill[]

  @@unique([name, householdId])
  @@index([householdId])
}

model Bill {
  id            String        @id @default(cuid())
  amount        Float
  description   String?
  dueDate       DateTime
  categoryId    String
  householdId   String
  paidById      String
  status        BillStatus   @default(PENDING)
  attachmentUrl String?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  category  Category   @relation(fields: [categoryId], references: [id])
  household Household  @relation(fields: [householdId], references: [id], onDelete: Cascade)
  paidBy    User       @relation(fields: [paidById], references: [id])
  payments  Payment[]

  @@index([householdId, dueDate])
  @@index([householdId, status])
  @@index([householdId, categoryId])
  @@index([paidById])
}

enum BillStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

model Payment {
  id        String   @id @default(cuid())
  billId    String
  userId    String
  amount    Float
  date      DateTime @default(now())
  notes     String?

  bill Bill @relation(fields: [billId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([billId, userId])
  @@index([billId])
  @@index([userId])
}

model AIInsight {
  id         String       @id @default(cuid())
  userId     String
  type       InsightType
  title      String
  content    String
  category   String?
  metadata   Json?
  isRead     Boolean      @default(false)
  createdAt  DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
}

enum InsightType {
  ANOMALY
  RECOMMENDATION
  PREDICTION
  PATTERN
  TIP
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      MessageRole
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
}

enum MessageRole {
  USER
  ASSISTANT
}